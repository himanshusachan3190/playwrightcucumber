{
  "name": "cucumber-playwright-javascript",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test:login.feature": "cucumber-js src/features/login.feature --format json:src/features/support/reports/cucumber-report.json --retry 1",
    "test:all": "cucumber-js \"src/features/**/*.feature\" --format json:src/features/support/reports/cucumber-report.json --retry 1",
    "test:rerun": "cucumber-js @rerun.txt --format json:src/features/support/reports/cucumber-report.json",
    "report": "node cucumber-html-reporter.js",
    "clean:screenshots": "node -e \"const fs=require('fs'),p='src/features/support/screenshots';if(fs.existsSync(p))fs.readdirSync(p).forEach(f=>fs.unlinkSync(p+'/'+f));console.log('Screenshots cleared.')\"",
    "clean:videos": "node -e \"const fs=require('fs'),p='src/features/support/videos';if(fs.existsSync(p))fs.readdirSync(p).forEach(f=>fs.unlinkSync(p+'/'+f));console.log('Videos cleared.')\"",
    "test:fresh": "npm run clean:screenshots && npm run clean:videos && npm run test:all && npm run report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@cucumber/cucumber": "^9.3.0",
    "dotenv": "^17.3.1",
    "playwright": "^1.36.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@playwright/test": "^1.59.1"
  }
}
